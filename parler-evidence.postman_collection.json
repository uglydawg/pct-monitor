                  "",
                  "pm.test('CC field fingerprint — influencer data', function () {",
                  "    const bodyStr = pm.response.text();",
                  "    const found = CC_FIELDS.filter(f => bodyStr.includes('\"' + f + '\"'));",
                  "    console.log('CC fields found:', found.join(', '));",
                  "    console.log('CC fingerprint score:', found.length + '/' + CC_FIELDS.length);",
                  "    pm.expect(found.length).to.be.greaterThan(0, 'Expected CC influencer fields');",
                  "});",
                  "",
                  "pm.test('ULID patterns in influencer data', function () {",
                  "    const bodyStr = pm.response.text();",
                  "    const ulidMatches = bodyStr.match(/\"[0-9a-hjkmnp-tv-z]{26}\"/g) || [];",
                  "    console.log('ULID values found:', ulidMatches.length);",
                  "    pm.expect(ulidMatches.length).to.be.greaterThan(0, 'Expected ULID values in influencer data');",
                  "});",
                  "",
                  "pm.test('CC structural: data envelope with post/user objects', function () {",
                  "    const body = pm.response.json();",
                  "    const hasData = body.hasOwnProperty('data');",
                  "    const bodyStr = pm.response.text();",
                  "    const hasEngagement = bodyStr.includes('userEngagement');",
                  "    const hasCounts = bodyStr.includes('impressionCount') || bodyStr.includes('upvoteCount');",
                  "    console.log('Has data:', hasData, '| Engagement:', hasEngagement, '| Counts:', hasCounts);",
                  "});"
                ]
              }
            }
          ]
        }
